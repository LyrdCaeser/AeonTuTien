<?xml version='1.0' encoding='utf-8'?>
<widget id="com.aeontutien.game" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
  <name>Aeon Tu Tien</name>
  <description>Web RPG built with React, Vite and Phaser.</description>
  <author email="trinhvu24689@gmail.com">AI The Ky 22</author>
  <content src="index.html" />
  <access origin="*" />
  <allow-navigation href="*" />
  <allow-intent href="http://*/*" />
  <allow-intent href="https://*/*" />
  <allow-intent href="tel:*" />
  <allow-intent href="sms:*" />
  <allow-intent href="mailto:*" />
  <allow-intent href="geo:*" />
  <preference name="android-minSdkVersion" value="24" />
  <preference name="android-targetSdkVersion" value="35" />
  <preference name="android-compileSdkVersion" value="35" />
  <preference name="android-buildToolsVersion" value="35.0.0" />
  <preference name="Fullscreen" value="true" />
  <preference name="Orientation" value="landscape" />
</widget>
